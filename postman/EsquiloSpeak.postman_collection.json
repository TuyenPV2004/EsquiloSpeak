  "item": [
    {
      "name": "Auth Guest Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Token is present and stored\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.accessToken).to.not.be.undefined;",
              "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
              "});",
              "",
              "pm.test(\"Verify user and device id details\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.userId).to.be.a('string');",
              "    pm.expect(jsonData.deviceId).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"deviceId\": \"{{deviceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/guest",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "guest"
          ]
        }
      },
      "response": []
    },

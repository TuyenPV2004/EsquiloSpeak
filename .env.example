POSTGRES_DB=EsquiloSpeak_db
POSTGRES_USER=esquilospeak
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5433

# Spring Boot datasource configuration for Maven local runs.
# Docker Compose backend profile overrides SPRING_DATASOURCE_URL to use the postgres service name.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/EsquiloSpeak_db
SPRING_DATASOURCE_USERNAME=esquilospeak
SPRING_DATASOURCE_PASSWORD=123456

# Eureka service discovery
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# JWT Security
JWT_SECRET=<CHANGE_ME_BASE64_RANDOM_32_BYTES_OR_MORE>

# Analytics Secrets
ANALYTICS_HASH_SECRET=<CHANGE_ME_RANDOM_32_BYTES_OR_MORE>

# Internal Service S2S Token Security
INTERNAL_SERVICE_TOKEN=<CHANGE_ME_RANDOM_32_BYTES_OR_MORE>

# URL of learning-service (used by content-service).
# If using Eureka load balancing, set to the service ID: http://learning-service
# For direct S2S calls (e.g. local dev without Eureka), set to: http://localhost:8084
LEARNING_SERVICE_URL=http://learning-service
